  "DataPrepConfiguration": {
    "SourceTableMap": {
      "src-summary-view": {
        "PhysicalTableId": "ae9f61a5-d48a-42ed-8b9c-e9f87a9f37fa"
      },
      "src-account-map": {
        "PhysicalTableId": "c0420538-7a33-4234-af0f-697600127f78"
      },
      "src-ri-sp-mapping": {
        "PhysicalTableId": "f756ee81-056c-4b8d-8bdb-fbce0eff48ba"
      }
    },
    "TransformStepMap": {
      "import-summary-view": {
        "ImportTableStep": {
          "Alias": "summary_view",
          "Source": {
            "SourceTableId": "src-summary-view"
          }
        }
      },
      "import-account-map": {
        "ImportTableStep": {
          "Alias": "account_map",
          "Source": {
            "SourceTableId": "src-account-map"
          }
        }
      },
      "import-ri-sp-mapping": {
        "ImportTableStep": {
          "Alias": "ri_sp_mapping",
          "Source": {
            "SourceTableId": "src-ri-sp-mapping"
          }
        }
      },
      "join-account-map": {
        "JoinStep": {
          "Alias": "Join with account_map",
          "Type": "LEFT",
          "OnClause": "{linked_account_id} = {account_id}",
          "LeftOperand": {
            "TransformOperationId": "import-summary-view"
          },
          "RightOperand": {
            "TransformOperationId": "import-account-map"
          }
        }
      },
      "join-ri-sp-mapping": {
        "JoinStep": {
          "Alias": "Join with ri_sp_mapping",
          "Type": "LEFT",
          "OnClause": "{billing_period} = {billing_period_mapping} AND {payer_account_id} = {payer_account_id_mapping} AND {ri_sp_arn} = {ri_sp_arn_mapping}",
          "LeftOperand": {
            "TransformOperationId": "join-account-map"
          },
          "RightOperand": {
            "TransformOperationId": "import-ri-sp-mapping"
          }
        }
      }
    },
    "DestinationTableMap": {
      "destination-summary-view": {
        "Alias": "summary_view",
        "Source": {
          "TransformOperationId": "join-ri-sp-mapping"
        }
      }
